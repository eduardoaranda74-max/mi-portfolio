---
// src/components/Skills.astro

const skillCategories = [
  {
    title: "Frontend",
    icon: "💻",
    skills: [
      { name: "HTML" },
      { name: "CSS" },
      { name: "JavaScript" },
      { name: "Bootstrap" },
      { name: "Astro" },
    ]
  },
  {
    title: "Backend",
    icon: "⚙️",
    skills: [
      { name: "PHP" },
      { name: "SQL" },
      { name: "MySQL" },
    ]
  },
  {
    title: "Herramientas",
    icon: "🛠️",
    skills: [
      { name: "Git" },
      { name: "GitHub" },
      { name: "Vercel" },
      { name: "VS Code" },
    ]
  },
  {
    title: "Otros",
    icon: "✨",
    skills: [
      { name: "SEO básico" },
      { name: "Diseño responsive" },
      { name: "WordPress" },
    ]
  }
];
---

<section id="habilidades" class="py-20 bg-slate-950">
  <div class="container mx-auto px-6">
    
    <div class="text-center mb-16">
      <span class="text-orange-500 font-semibold text-sm uppercase tracking-wider">Mi Stack</span>
      <h2 class="text-4xl md:text-5xl font-bold text-white mt-2">
        Habilidades
      </h2>
      <p class="text-slate-400 text-lg mt-4 max-w-2xl mx-auto">
        Tecnologías y herramientas con las que trabajo para crear soluciones increíbles
      </p>
    </div>

    <div class="grid md:grid-cols-2 gap-6 mb-16">
      {skillCategories.map((category) => (
        <div class="bg-slate-900 border-2 border-slate-800 rounded-2xl p-8 hover:border-orange-500 transition-all duration-300 hover:-translate-y-2 hover:shadow-2xl hover:shadow-orange-500/20">
          
          <div class="flex items-center gap-4 mb-6">
            <span class="text-4xl">{category.icon}</span>
            <h3 class="text-2xl font-bold text-white">{category.title}</h3>
          </div>
          
          <div class="flex flex-wrap gap-2">
            {category.skills.map((skill) => (
              <span class="px-3 py-1 bg-slate-800 text-slate-300 font-semibold rounded-full text-sm border border-slate-700 hover:border-orange-500 hover:text-orange-400 transition-colors duration-200">
                {skill.name}
              </span>
            ))}
          </div>
          
        </div>
      ))}
    </div>

    <div class="border-t border-slate-800 pt-16">
      <h3 class="text-2xl font-bold text-white text-center mb-10">
        Tecnologías que uso:
      </h3>
      
      <div class="flex flex-wrap justify-center gap-8">
        <div class="flex flex-col items-center gap-2 group cursor-pointer transition-transform hover:-translate-y-2">
          <img
            src="https://cdn.jsdelivr.net/gh/devicons/devicon/icons/html5/html5-original.svg"
            alt="HTML5"
            class="w-16 h-16 transition-all"
          />
          <span class="text-slate-400 text-sm font-semibold group-hover:text-orange-500">HTML5</span>
        </div>

        <div class="flex flex-col items-center gap-2 group cursor-pointer transition-transform hover:-translate-y-2">
          <img
            src="https://cdn.jsdelivr.net/gh/devicons/devicon/icons/css3/css3-original.svg"
            alt="CSS3"
            class="w-16 h-16 transition-all"
          />
          <span class="text-slate-400 text-sm font-semibold group-hover:text-orange-500">CSS3</span>
        </div>

        <div class="flex flex-col items-center gap-2 group cursor-pointer transition-transform hover:-translate-y-2">
          <img
            src="https://cdn.jsdelivr.net/gh/devicons/devicon/icons/javascript/javascript-original.svg"
            alt="JavaScript"
            class="w-16 h-16 transition-all"
          />
          <span class="text-slate-400 text-sm font-semibold group-hover:text-orange-500">JavaScript</span>
        </div>

        <div class="flex flex-col items-center gap-2 group cursor-pointer transition-transform hover:-translate-y-2">
          <img
            src="https://cdn.jsdelivr.net/gh/devicons/devicon/icons/php/php-original.svg"
            alt="PHP"
            class="w-16 h-16 transition-all"
          />
          <span class="text-slate-400 text-sm font-semibold group-hover:text-orange-500">PHP</span>
        </div>

        <div class="flex flex-col items-center gap-2 group cursor-pointer transition-transform hover:-translate-y-2">
          <img
            src="https://cdn.jsdelivr.net/gh/devicons/devicon/icons/mysql/mysql-original.svg"
            alt="MySQL"
            class="w-16 h-16 transition-all"
          />
          <span class="text-slate-400 text-sm font-semibold group-hover:text-orange-500">MySQL</span>
        </div>

        <div class="flex flex-col items-center gap-2 group cursor-pointer transition-transform hover:-translate-y-2">
          <img
            src="https://cdn.jsdelivr.net/gh/devicons/devicon/icons/bootstrap/bootstrap-original.svg"
            alt="Bootstrap"
            class="w-16 h-16 transition-all"
          />
          <span class="text-slate-400 text-sm font-semibold group-hover:text-orange-500">Bootstrap</span>
        </div>

        <div class="flex flex-col items-center gap-2 group cursor-pointer transition-transform hover:-translate-y-2">
          <img
            src="https://cdn.jsdelivr.net/gh/devicons/devicon/icons/git/git-original.svg"
            alt="Git"
            class="w-16 h-16 transition-all"
          />
          <span class="text-slate-400 text-sm font-semibold group-hover:text-orange-500">Git</span>
        </div>
      </div>
    </div>

  </div>
</section>