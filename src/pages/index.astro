---
// src/pages/index.astro
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import About from '../components/About.astro';
import Skills from '../components/Skills.astro';
import ProjectFilters from '../components/ProjectFilters.jsx';
import Contacto from '../components/Contacto.astro';

const proyectos = [
    {
        title: "Estudio Jurídico EGZ",
        description: "Sitio web profesional para estudio de abogados. Presenta los servicios, el equipo y facilita el contacto con los clientes.",
        tags: ["HTML", "CSS", "Bootstrap"],
        url: "https://estudio-juridico-egz-y5d6.vercel.app/"
    },
    {
        title: "SuperCartas",
        description: "Aplicación web para crear y compartir cartas digitales personalizadas. Diseño atractivo y experiencia de usuario cuidada.",
        tags: ["HTML", "CSS", "JavaScript"],
        url: "https://supercartas.vercel.app/"
    },
    {
        title: "Auto Credit Solutions",
        description: "Sistema web completo para concesionaria de vehículos. Incluye catálogo público con galería, panel de administración con CRUD de vehículos, clientes y pedidos.",
        tags: ["PHP", "MySQL", "Bootstrap"],
        url: "https://github.com/eduardoaranda74-max/concesionaria"
    },
    {
        title: "Adriana Godoy Propiedades",
        description: "Sitio web inmobiliario para agencia de propiedades. Muestra listado de inmuebles disponibles y facilita el contacto con la agente.",
        tags: ["HTML", "CSS", "JavaScript"],
        url: "https://eduardoaranda74-max.github.io/AdrianaGodoyPropiedades/"
    },
];
---

<Layout title="Eduardo Aranda - Portfolio">
    <!-- Hero Section -->
    <Hero />

    <!-- About Section -->
    <About />

    <!-- Skills Section -->
    <Skills />

    <!-- Projects Section -->
    <main id="proyectos" class="bg-slate-950 py-20">
        <div class="container mx-auto px-6">
            <div class="text-center mb-16">
                <span class="text-orange-500 font-semibold text-sm uppercase tracking-wider">Mi Trabajo</span>
                <h2 class="text-4xl md:text-5xl font-bold text-white mt-2">
                    Mis <span class="text-orange-500">Proyectos</span>
                </h2>
            </div>
            
            <ProjectFilters initialProjects={proyectos} client:load />
        </div>
    </main>

    <!-- Contact Section -->
    <Contacto />
</Layout>